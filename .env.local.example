# Copy this file to .env.local and fill in your own Supabase project's values.
# Find both of these in your Supabase project dashboard under Settings -> API.
# The anon key is safe to expose in the browser — that's what it's designed for.
# Row Level Security (see supabase/migrations/0005_rls.sql) is what actually protects data, not key secrecy.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
